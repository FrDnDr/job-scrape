DATABASE_URL=postgresql+psycopg://jobs:jobs@localhost:5432/job_intelligence
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat

# Supported models via OpenRouter:
#   deepseek/deepseek-chat        (default, fast + cheap)
#   qwen/qwen-2.5-72b-instruct
#   google/gemini-flash-1.5
#   anthropic/claude-3-haiku

ALLOWED_ORIGINS=http://localhost:3000
REMOTEOK_USER_AGENT=CareerLens/1.0
ONLINEJOBS_USER_AGENT=Mozilla/5.0 (compatible; CareerLens/1.0)

# Local Docker Postgres credentials
POSTGRES_DB=job_intelligence
POSTGRES_USER=jobs
POSTGRES_PASSWORD=changeme
